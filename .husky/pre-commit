#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🦉 HOOTNER - Running pre-commit validations..."
echo ""

# 1. Scan for secrets (passwords, tokens, keys)
echo "🔍 [1/3] Scanning for secrets..."
node scripts/scan-secrets.js
if [ $? -ne 0 ]; then
  echo "❌ Secret scanning failed. Commit aborted."
  exit 1
fi

# 2. Check syntax using ESLint
echo "🔧 [2/3] Running ESLint syntax check..."
STAGED_JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(js|jsx|mjs|cjs)$' || true)
if [ -n "$STAGED_JS_FILES" ]; then
  npx eslint --max-warnings 0 --quiet $STAGED_JS_FILES
  if [ $? -ne 0 ]; then
    echo "❌ ESLint check failed. Please fix syntax errors."
    echo "💡 Run 'npm run lint:fix' to auto-fix some issues."
    exit 1
  fi
else
  echo "⏭️  No JavaScript files staged for commit."
fi

# 3. Run the enhanced code review agent (optional - will not block commit if fails)
echo "👀 [3/3] Running enhanced code review..."
if node code-review-agent.js 2>/dev/null; then
  echo "✅ Code review passed!"
else
  echo "⚠️  Code review skipped (agent unavailable or has errors)"
  echo "💡 This is optional and won't block your commit"
fi

echo ""
echo "✅ All pre-commit checks passed!"
