apps/frontend/html-pages/electron-code-editor/

# Python files (not JavaScript)
**/*.py
**/*.pyc

# Configuration files that shouldn't be linted
**/*.json
**/*.yaml
**/*.yml
**/*.toml
**/*.conf
**/*.config
**/*.env*

# Binary and installer files
tools/installers/
**/*.exe
**/*.msi

# Generated reports
**/*-report.txt
**/*-report.md
code-scan-report.temp
eslint-report.json
lint-*.txt

# Test artifacts
**/*.spec.js
**/*.test.js
tests/

# Legacy and backup files
src/legacy/
**/*.bak
**/*.backup

