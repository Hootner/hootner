# Minified libraries
apps/frontend/html-pages/libs/*.min.js
**/*.min.js

# Build output
dist/
build/
out/

# Dependencies
node_modules/

# Generated files
coverage/
.next/

# Logs and temporary files
logs/
temp/
data/logs/
*.log

# Cache and state files
.pm2/
.aws/
.codegpt/
.claude/
.kiro/
