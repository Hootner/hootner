{ "name": "hootner-code-editor",
  "version": "1.0.0",
  "description": "HOOTNER Code Editor - Enterprise-grade code editor with AI, Git, and collaboration",
  "main": "main.js",
  "scripts": { "start": "electron .",
    "test": "playwright test",
    "test:e2e": "playwright test --headed",
    "test:unit": "vitest",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl" },
  "config": { "forge": { "packagerConfig": { "icon": "./assets/icon",
        "asar": true },
      "makers": [
        { "name": "@electron-forge/maker-squirrel",
          "config": { "name": "hootner_code_editor" } },
        { "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ] },
        { "name": "@electron-forge/maker-deb",
          "config": {} },
        { "name": "@electron-forge/maker-rpm",
          "config": {} }
      ],
      "publishers": [
        { "name": "@electron-forge/publisher-github",
          "config": { "repository": { "owner": "hootner",
              "name": "code-editor" },
            "prerelease": false } }
      ] } },
  "build": { "appId": "com.hootner.codeeditor",
    "productName": "HOOTNER Code Editor",
    "directories": { "output": "dist" },
    "files": [
      "**/*",
      "!**/*.ts",
      "!*.map"
    ],
    "win": { "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico" },
    "mac": { "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools" },
    "linux": { "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "icon": "assets/icon.png",
      "category": "Development" },
    "publish": { "provider": "github",
      "owner": "hootner",
      "repo": "code-editor" } },
  "dependencies": { "electron-updater": "^6.1.7" },
  "devDependencies": { "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/publisher-github": "^7.2.0",
    "@playwright/test": "^1.40.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vitest": "^1.0.0" },
  "author": "HOOTNER Team",
  "license": "MIT" }
