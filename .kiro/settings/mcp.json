{
  "mcpServers": {
    "hootner-enhanced-mcp": {
      "command": "node",
      "args": ["hexarchy/3-communication/adapters/enhanced-mcp-server.js"],
      "env": {
        "NODE_ENV": "development",
        "HOOTNER_MCP_VERSION": "2.0.0"
      },
      "disabled": false,
      "autoApprove": ["dual_agent_route", "agent_hub_status", "list_agents_by_category"],
      "allowStdin": true,
      "capabilities": {
        "experimental": {
          "progressNotifications": true
        }
      }
    },
    "hootner-legacy-mcp": {
      "command": "node",
      "args": ["hexarchy/3-communication/adapters/mcp-server.js"],
      "env": {
        "NODE_ENV": "development",
        "HOOTNER_MCP_VERSION": "1.0.0"
      },
      "disabled": true,
      "autoApprove": []
    }
  }
}
