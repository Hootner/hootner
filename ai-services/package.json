{
  "name": "transformer-api-server",
  "version": "1.0.0",
  "description": "Node.js API server for PyTorch Transformer with GPT-3.5 integration",
  "main": "transformer-api-server.js",
  "scripts": {
    "start": "node transformer-api-server.js",
    "dev": "nodemon transformer-api-server.js",
    "start:python": "python LLM.py",
    "start:all": "concurrently \"npm run start:python\" \"npm run start\""
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^3.3.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
