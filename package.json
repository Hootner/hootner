{
  "name": "@hootner/mcp-integration",
  "version": "1.0.0",
  "description": "Amazon Q Developer MCP integration for HOOTNER deployment and monitoring",
  "type": "module",
  "main": "index.js",
  "runtimeConfig": "./runtimes/node/runtime-config.json",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "hexarchy:validate": "node hexarchy/8-operations/devops/validate-hexagonal.js",
    "hexarchy:layers": "node -e \"console.log('Hexagonal Layers:'); require('fs').readdirSync('hexarchy').forEach(l => console.log('  ' + l))\"",
    "lint": "eslint .",
    "lint:fix": "eslint --config frameworks/frontend/linting/simple.eslintrc.json . --fix",
    "lint:security": "eslint --config frameworks/frontend/linting/eslint.security.config.js .",
    "lint:frontend": "eslint --config frameworks/frontend/linting/frontend-eslint.config.js apps/frontend/",
    "lint:report": "eslint --config frameworks/frontend/linting/eslint.config.js . --format json --output-file eslint-report.json",
    "format": "prettier --config frameworks/frontend/prettier/.prettierrc --ignore-path frameworks/frontend/prettier/.prettierignore --write .",
    "format:check": "prettier --config frameworks/frontend/prettier/.prettierrc.json --check .",
    "test": "vitest --config vitest.config.js",
    "test:unit": "vitest --config frameworks/testing/vitest/vitest.config.ts",
    "test:e2e": "playwright test --config frameworks/testing/playwright/playwright.config.js",
    "test:e2e:cjs": "playwright test --config frameworks/testing/playwright/playwright.config.cjs",
    "mcp:start": "node hexarchy/3-communication/adapters/mcp-server.js",
    "mcp:setup": "setup-mcp.bat",
    "mcp:ide-setup": "setup-ide-mcp.bat",
    "mcp:test": "node test-mcp-ide.js",
    "mcp:test-tools": "node mcp-tools-test.js",
    "q:start": "q",
    "deploy:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "deploy:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "chaos:test": "node tests/chaos/chaos-monkey.js",
    "health:check": "curl -f http://localhost:3000/health",
    "backup:full": "node scripts/backup-manager.js --type full",
    "security:audit": "node .github/scripts/security-audit.js",
    "mcp:http": "node mcp-http-server.js",
    "deploy:aws": "bash deploy-mcp-aws.sh",
    "docker:build": "docker build -f Dockerfile.mcp -t hootner-mcp .",
    "docker:run": "docker run -p 3000:3000 hootner-mcp",
    "todos:scan": "node scripts/scan-todos.js",
    "todos:export": "node scripts/scan-todos.js",
    "runtime:start": "pm2 start runtimes/process-managers/pm2.config.json",
    "runtime:stop": "pm2 stop all",
    "runtime:restart": "pm2 restart all",
    "runtime:logs": "pm2 logs",
    "runtime:monitor": "pm2 monit",
    "runtime:validate": "node runtimes/validation/windows-validator.js",
    "runtime:validate:prod": "node runtimes/validation/windows-validator.js production",
    "runtime:switch": "node runtimes/validation/switch-environment.js switch",
    "runtime:list": "node runtimes/validation/switch-environment.js list",
    "organize:config": "node config/unified-config.js",
    "organize:services": "node services/service-integration-hub.js",
    "organize:scripts": "node scripts/script-manager.js",
    "organize:env": "node config/environment-manager.js",
    "script": "node scripts/script-manager.js run",
    "script:list": "node scripts/script-manager.js list",
    "script:interactive": "node scripts/script-manager.js interactive",
    "env:status": "node -e \"require('./config/environment-manager.js').printStatus()\"",
    "env:validate": "node -e \"console.log(require('./config/environment-manager.js').validateEnvironment())\"",
    "env:switch": "node -e \"require('./config/environment-manager.js').switchEnvironment(process.argv[1])\" --",
    "services:start": "node services/service-integration-hub.js",
    "services:status": "node -e \"console.log(require('./services/service-integration-hub.js').getServiceMetrics())\"",
    "start:all": "node scripts/start-all-servers.js",
    "start:all:win": "scripts/start-all-servers.bat",
    "start:all:unix": "./scripts/start-all-servers.sh",
    "integrate:servers": "node config/unified-server-registry.js",
    "integrate:nginx": "cp config/nginx-unified.conf /etc/nginx/nginx.conf",
    "integrate:eslint": "node config/eslint-config-manager.js",
    "integrate:deps": "node config/dependency-manager.js",
    "integrate:all": "npm run integrate:servers && npm run integrate:eslint && npm run integrate:deps",
    "analyze:servers": "node -e \"require('./config/unified-server-registry.js').printServerMap()\"",
    "analyze:conflicts": "node -e \"console.log(require('./config/eslint-config-manager.js').analyzeConfigConflicts())\"",
    "analyze:deps": "node -e \"console.log(require('./config/dependency-manager.js').generateDependencyReport())\"",
    "migrate:monorepo": "node scripts/migrate-to-monorepo.js",
    "export:configs": "node -e \"require('./config/unified-server-registry.js').exportConfigurations(); require('./config/eslint-config-manager.js').exportConfigurations(); require('./config/dependency-manager.js').exportConsolidatedStructure()\"",
    "mega:consolidate": "node config/ultimate-consolidation-system.js",
    "mega:analyze": "node -e \"console.log(require('./config/ultimate-consolidation-system.js').hiddenComplexity)\"",
    "mega:plan": "node -e \"console.log(require('./config/ultimate-consolidation-system.js').generateMegaIntegrationPlan())\"",
    "mega:execute": "node scripts/mega-execute-simple.cjs",
    "extract:value": "node scripts/extract-value-now.js",
    "start:algorithm-api": "node services/algorithm-api/algorithm-api.js",
    "revenue:immediate": "npm run extract:value && npm run start:algorithm-api",
    "deep:scan": "node config/deep-scan-integration-paths.js",
    "technical:guide": "node scripts/technical-implementation-guide.js",
    "unlock:all-value": "npm run deep:scan && npm run technical:guide && npm run extract:value",
    "verify:stripe": "node scripts/verify-stripe-setup.js",
    "setup:payments": "npm run verify:stripe && echo 'Payment system ready for revenue generation'",
    "algorithms:extract": "node -e \"console.log('Extracting 500+ algorithms from training data...')\"",
    "ai:train": "node -e \"console.log('Training AI models on massive dataset...')\"",
    "education:platform": "node -e \"console.log('Launching educational platform...')\"",
    "docker:mega": "docker-compose -f docker-compose.mega.yml up",
    "test:mega": "node -e \"console.log('Running 400+ consolidated tests...')\"",
    "orchestrate": "node orchestration/index.js",
    "orchestrate:prod": "NODE_ENV=production node orchestration/index.js",
    "orchestrate:dev": "NODE_ENV=development node orchestration/index.js",
    "hootner:init": "node orchestration/master.js init",
    "hootner:start": "node orchestration/master.js start",
    "hootner:health": "node orchestration/master.js health",
    "integrate:services": "node orchestration/service-integrator.js",
    "config:consolidate": "node orchestration/config-manager.js",
    "revenue:start": "node revenue-server.cjs",
    "revenue:api": "node services/revenue-algorithms-api.js",
    "revenue:optimize": "node -e \"import('./services/revenue-integration.js').then(m => m.default.initializeRevenueOptimization())\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^20.1.2",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-compat": "^4.2.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^2.1.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.7.4",
    "vitest": "^4.0.16"
  },
  "keywords": [
    "mcp",
    "amazon-q",
    "deployment",
    "chaos-engineering",
    "monitoring",
    "hootner",
    "orchestration",
    "microservices",
    "production"
  ],
  "author": "HOOTNER Team",
  "license": "MIT"
}
