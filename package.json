{
  "name": "hootner-mcp-integration",
  "version": "1.0.0",
  "description": "Amazon Q Developer MCP integration for HOOTNER deployment and monitoring",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:report": "eslint . --output-file docs/reports/eslint-report.json --format json",
    "mcp:start": "node servers/hootner-mcp-server.js",
    "mcp:setup": "node scripts/setup-pm2.js",
    "mcp:ide-setup": "node scripts/ide-setup.js",
    "mcp:test": "node mcp-tools-test.js",
    "mcp:test-tools": "node mcp-tools-test.js",
    "deploy:dev": "node scripts/deploy-dev.js",
    "deploy:prod": "node scripts/deploy-prod.js",
    "deploy:blue-green": "bash scripts/blue-green-deploy.sh",
    "security:audit": "npm audit --json > docs/reports/security-audit.json || echo 'Audit complete'",
    "security:scan": "snyk test --all-projects",
    "chaos:test": "node scripts/chaos-test.js",
    "chaos:network": "node scripts/chaos-network.js",
    "chaos:cpu": "node scripts/chaos-cpu.js",
    "backup:full": "node scripts/backup-full.js",
    "backup:incremental": "node scripts/backup-incremental.js",
    "backup:restore": "node scripts/backup-restore.js",
    "collab": "node servers/collab-server.js",
    "dev:secure": "node servers/secure-server.js",
    "start:all": "node start-all-servers.js",
    "transformer": "node start-transformer.js",
    "test": "echo 'Running tests...'",
    "test:unit": "echo 'Running unit tests...'",
    "test:integration": "echo 'Running integration tests...'",
    "test:e2e": "echo 'Running e2e tests...'",
    "test:load": "echo 'Running load tests...'",
    "test:chaos": "npm run chaos:test",
    "docker:build": "docker build -t hootner-mcp .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "k8s:deploy": "kubectl apply -f k8s/",
    "k8s:delete": "kubectl delete -f k8s/",
    "metrics:collect": "node scripts/collect-metrics.js",
    "logs:view": "tail -f logs/combined.log",
    "logs:view:errors": "tail -f logs/errors/*.log",
    "logs:view:services": "tail -f logs/services/*.log",
    "logs:view:servers": "tail -f logs/servers/*.log",
    "logs:clear": "node scripts/clear-logs.js",
    "update:context": "node scripts/update-context.js",
    "dashboard": "node scripts/dashboard.js",
    "status": "node scripts/check-services.js",
    "map": "node scripts/dependency-map.js",
    "visibility": "npm run dashboard && npm run status && npm run map",
    "log:chat": "node scripts/log-chat.js",
    "training:run": "node run-training-pipeline.js",
    "check:sources": "node check-training-sources.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.6",
    "dotenv": "^16.3.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "nodemon": "^3.0.1",
    "snyk": "^1.1200.0"
  }
}
