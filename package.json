{
  "name": "hootner",
  "version": "1.0.0",
  "type": "module",
  "description": "🦉 HOOTNER - The Owl Never Sleeps - Ultimate Video Player & Social Platform",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:api\"",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:api": "cd api/graphql && npm run dev",
    "dev:hub": "cd apps/frontend && npm run dev:hub",
    "dev:secure": "cd apps/frontend && npm run dev:secure",
    "collab": "node collaboration-server.js",
    "package": "electron-builder",
    "make": "electron-forge make",
    "test": "npm run test:frontend && npm run test:api && npm run test:chaos",
    "test:frontend": "cd apps/frontend && npm test",
    "test:api": "cd api/graphql && npm test",
    "test:chaos": "node tests/chaos/chaos-monkey.js",
    "test:load": "node tests/chaos/load-test.js",
    "test:smoke": "node tests/smoke-test.js",
    "lint": "npm run lint:js && npm run lint:html && npm run lint:css",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:html": "htmlhint apps/frontend/html-pages/*.html",
    "lint:css": "stylelint **/*.css",
    "lint:css:fix": "stylelint **/*.css --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run format",
    "lint:all": "node scripts/lint-all.js",
    "lint:all:fix": "node scripts/lint-all.js --fix",
    "fix:syntax": "node scripts/fix-syntax-errors.js",
    "fix:regex": "node scripts/fix-regex-issues.cjs",
    "fix:all-syntax": "node scripts/fix-all-syntax.cjs",
    "detect:regex": "node scripts/find-unterminated-regex.cjs",
    "detect:jsdoc": "node scripts/find-malformed-jsdoc.cjs",
    "verify:syntax": "node scripts/verify-syntax-fixes.cjs",
    "build": "npm run build:frontend && npm run build:api",
    "build:frontend": "cd apps/frontend && npm run build",
    "build:api": "cd api/graphql && npm run build",
    "analyze:duplication": "node scripts/analyze-duplication.js",
    "docs:generate": "jsdoc -c jsdoc.config.json",
    "docs:serve": "http-server docs/generated -p 8080",
    "security:audit": "npm audit && node scripts/security-audit.js",
    "security:scan": "node scripts/security-scanner.js",
    "security:validate-env": "node scripts/validate-env.js",
    "generate:secrets": "node scripts/generate-secrets.js",
    "video:install": "cd services/video-generation && python install.py",
    "video:start": "cd services/video-generation && python api.py",
    "video:example": "cd services/video-generation && python example.py",
    "ai:setup": "npm run video:install && echo 'AI video generation ready!'",
    "services:start": "concurrently \"npm run video:start\" \"npm start\"",
    "docker:build": "docker-compose -f docker-compose.dev.yml build",
    "docker:up": "docker-compose -f docker-compose.dev.yml up",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "k8s:deploy": "kubectl apply -f k8s/",
    "backup": "node scripts/backup-manager.js",
    "deploy:blue-green": "./scripts/blue-green-deploy.sh",
    "prepare": "husky"
  },
  "keywords": [
    "video-player",
    "social-platform",
    "pwa",
    "ai-generation",
    "microservices",
    "kubernetes",
    "diffusion-models"
  ],
  "author": "HOOTNER Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dompurify": "^3.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "helmet": "^7.0.0",
    "isomorphic-dompurify": "^2.34.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "prom-client": "^14.2.0",
    "redis": "^4.6.7",
    "sharp": "^0.32.5",
    "socket.io": "^4.7.2",
    "stripe": "^13.5.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "concurrently": "^8.2.0",
    "electron": "^39.2.7",
    "electron-builder": "^24.6.3",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^50.8.0",
    "eslint-plugin-prettier": "^5.5.4",
    "htmlhint": "^1.8.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^29.6.2",
    "jsdoc": "^4.0.2",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.2",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/hootner.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/hootner/issues"
  },
  "homepage": "https://github.com/yourusername/hootner#readme"
}
