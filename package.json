{
  "name": "@hootner/enterprise-platform",
  "version": "1.0.0",
  "description": "HOOTNER - Enterprise Video Streaming Platform with AI Integration",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "onboard": "node scripts/onboard-dev.js",
    "start": "node index.js",
    "start:hootner": "node start-hootner.js",
    "start:enhanced": "node serve-html-enhanced.js",
    "start:basic": "node serve-html-basic.js",
    "collaboration": "node serve-html-enhanced.js",
    "agents:manage": "node enhanced-agent-hub.js",
    "devops:monitor": "node serve-html-enhanced.js",
    "launch:platform": "node launch-platform.js",
    "launch:advanced": "node advanced-platform-launcher.js",
    "platform:status": "node advanced-platform-launcher.js status",
    "platform:metrics": "node advanced-platform-launcher.js metrics",
    "platform:restart": "node advanced-platform-launcher.js restart",
    "start:api": "cd api/graphql && npm start",
    "start:backend": "node scripts/start-backend.js",
    "start:platform": "node start-platform-complete.js",
    "start:all": "node index.js",

    "deploy:aws": "node scripts/deploy-aws.js",
    "aws:check": "aws sts get-caller-identity",
    "aws:package": "sam build",
    "aws:deploy": "sam deploy --guided",
    "db:setup": "node scripts/setup-dynamodb.js",
    "db:optimize": "echo 'DynamoDB optimization not needed for local development'",
    "aws:setup": "node scripts/aws-setup.js",
    "backend:validate": "node scripts/validate-backend.js",
    "dev": "nodemon index.js",
    "build": "npm run build:frontend && npm run build:api",
    "build:frontend": "echo 'Building frontend...'",
    "build:api": "cd api/graphql && npm run build",
    "test": "jest --config jest.config.js",
    "test:unit": "jest --config jest.config.js",
    "test:e2e": "playwright test",
    "test:integration": "jest tests/integration",
    "test:smoke": "node scripts/smoke-test.js || echo 'Smoke test script not found, skipping...'",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
    "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "py:format": "python -m black .",
    "py:format:check": "python -m black --check .",
    "py:lint": "python -m ruff .",
    "tools:format:all": "npm run format && npm run py:format",
    "tools:lint:all": "npm run lint && npm run py:lint",
    "security:audit": "npm audit && node security-audit.js",
    "security:fix": "npm audit fix",
    "security:report": "node security-audit.js",
    "git:integrity:report": "node scripts/git-integrity-check.js report",
    "git:integrity:check": "node scripts/git-integrity-check.js pre-commit",
    "git:health:monitor": "node scripts/git-health-monitor.js",
    "git:health:history": "node scripts/git-health-monitor.js history",
    "git:health:save": "node scripts/git-health-monitor.js save",
    "commit": "cz",
    "commit:merge": "node copilot-delegate.js merge",

    "infra:deploy": "node hexarchy/8-operations/infrastructure/infrastructure-manager.js",
    "infra:terraform": "cd terraform && terraform init && terraform plan",
    "infra:terraform:apply": "cd terraform && terraform apply",
    "db:migrate": "node hexarchy/7-data/storage/database-manager.js",
    "db:seed": "node scripts/seed-database.js",
    "containers:start": "node hexarchy/1-foundation/containers/container-manager.js",
    "ai:agents": "node hexarchy/5-economy/business/ai/run-all-agents.js",
    "payment:service": "node hexarchy/5-economy/business/commerce/payment-service.js",
    "monitor:performance": "node hexarchy/5-economy/business/analytics/performance-monitor.js",
    "health:check": "curl -f http://localhost:3000/api/health || exit 1",
    "backup:create": "node scripts/backup-manager.js --create",
    "backup:restore": "node scripts/backup-manager.js --restore",
    "logs:view": "tail -f data/logs/system/*.log",
    "logs:clear": "rm -rf data/logs/system/*.log",
    "deploy:staging": "npm run build && npm run docker:compose:dev",
    "deploy:production": "npm run build && npm run docker:compose:prod",
    "orchestrator": "node agent-orchestrator-cli.js",
    "orchestrator:init": "node agent-orchestrator-cli.js init",
    "orchestrator:analyze": "node agent-orchestrator-cli.js analyze",
    "orchestrator:deploy": "node agent-orchestrator-cli.js deploy",
    "orchestrator:docs": "node agent-orchestrator-cli.js docs",
    "orchestrator:maintenance": "node agent-orchestrator-cli.js maintenance",
    "orchestrator:status": "node agent-orchestrator-cli.js status",
    "hexarchy:scale": "node hexarchy-scaler.js",
    "dual-agent:start": "node start-dual-agent.js",
    "dual-agent:enable": "node scripts/dual-agent-switcher.js enable",
    "dual-agent:disable": "node scripts/dual-agent-switcher.js disable",
    "dual-agent:status": "node scripts/dual-agent-switcher.js status",
    "aws:validate": "node scripts/aws-config-validator.js",
    "aws:configure": "aws configure",
    "aws:identity": "aws sts get-caller-identity",
    "postinstall": "cd api/graphql && npm install",
    "py:precommit:install": "python -m pip install --user pre-commit || true && python -m pre_commit install || true",
    "py:precommit:run": "python -m pre_commit run --all-files || true",
    "prepare": "husky install"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.974.0",
    "@aws-sdk/lib-dynamodb": "^3.974.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "esbuild": "^0.27.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "graphql": "^16.12.0",
    "graphql-subscriptions": "^3.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.10",
    "socket.io": "^4.8.3",
    "stripe": "^14.9.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "commitizen": "^4.2.4",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.55.0",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "ora": "^7.0.1",
    "prettier": "^3.1.0",
    "ts-jest": "^29.4.6"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.py": [
      "python -m ruff",
      "python -m black --quiet --fast"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "keywords": [
    "video-streaming",
    "ai-platform",
    "enterprise",
    "hexagonal-architecture",
    "microservices",
    "graphql",
    "docker",
    "kubernetes",
    "aws",
    "terraform"
  ],
  "author": "HOOTNER Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hootner/enterprise-platform.git"
  },
  "bugs": {
    "url": "https://github.com/hootner/enterprise-platform/issues"
  },
  "homepage": "https://hootner.com"
}
