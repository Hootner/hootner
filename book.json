{
  "title": "HOOTNER Documentation",
  "description": "The Owl Never Sleeps - Ultimate Video Player & Social Platform",
  "author": "HOOTNER Team",
  "language": "en",
  "gitbook": ">=3.0.0",
  "plugins": [
    "search",
    "github",
    "edit-link",
    "prism",
    "-highlight",
    "copy-code-button",
    "expandable-chapters",
    "back-to-top-button",
    "theme-comscore"
  ],
  "pluginsConfig": {
    "github": {
      "url": "https://github.com/yourusername/hootner"
    },
    "edit-link": {
      "base": "https://github.com/yourusername/hootner/edit/main",
      "label": "Edit This Page"
    },
    "theme-default": {
      "showLevel": true
    }
  },
  "links": {
    "sidebar": {
      "GitHub": "https://github.com/yourusername/hootner",
      "Support": "mailto:support@hootner.com"
    }
  }
}
