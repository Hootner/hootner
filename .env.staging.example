# Staging Environment Configuration
# Copy this to .env.staging for staging deployment

NODE_ENV=staging

# Database - DynamoDB (Staging)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_staging_access_key
AWS_SECRET_ACCESS_KEY=your_staging_secret_key
DYNAMODB_TABLE_NAME=hootner-staging

# Redis (Staging)
REDIS_URL=redis://your-redis-staging.cache.amazonaws.com:6379
REDIS_PASSWORD=your_staging_redis_password

# Authentication (Staging)
JWT_SECRET=your_staging_jwt_secret_here
SESSION_SECRET=your_staging_session_secret_here

# API Ports
API_PORT=4000
FRONTEND_PORT=3000

# AWS Services (Staging)
S3_BUCKET=hootner-uploads-staging
S3_REGION=us-east-1
AWS_S3_BUCKET=hootner-frontend-staging
CLOUDFRONT_DIST_ID=your_staging_cloudfront_id
CLOUDFRONT_URL=https://cdn-staging.hootner.com

# Stripe (Staging - Use TEST keys!)
STRIPE_SECRET_KEY=sk_test_your_staging_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_staging_key

# Video Generation (Staging)
VIDEO_GEN_PORT=5003

# Frontend API Endpoints (Staging)
VITE_API_BASE=https://api-staging.hootner.com
VITE_WS_URL=wss://ws-staging.hootner.com
VITE_GRAPHQL_API=https://api-staging.hootner.com/graphql
VITE_GRAPHQL_WS=wss://api-staging.hootner.com/graphql
VITE_VIDEO_API=https://video-staging.hootner.com
VITE_VIDEO_PLAYER_API=https://player-staging.hootner.com
VITE_ANALYTICS_API=https://analytics-staging.hootner.com/api
VITE_WATCH_PARTY_WS=wss://watchparty-staging.hootner.com
VITE_LSP_JAVASCRIPT=wss://lsp-staging.hootner.com/javascript
VITE_LSP_TYPESCRIPT=wss://lsp-staging.hootner.com/typescript
VITE_LSP_PYTHON=wss://lsp-staging.hootner.com/python
VITE_LSP_JAVA=wss://lsp-staging.hootner.com/java
VITE_LSP_CPP=wss://lsp-staging.hootner.com/cpp
VITE_MESSAGES_API=https://api-staging.hootner.com/api/messages
VITE_MARKETPLACE_API=https://api-staging.hootner.com/api/marketplace
VITE_CONTACT_API=https://api-staging.hootner.com/api/contact

# Staging-specific settings
LOG_LEVEL=debug
ENABLE_MONITORING=true
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=900000
