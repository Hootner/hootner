# Production Environment Configuration
# Copy this to .env.production and update with your production values

NODE_ENV=production

# Database - DynamoDB (Production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_production_access_key
AWS_SECRET_ACCESS_KEY=your_production_secret_key
DYNAMODB_TABLE_NAME=hootner-prod

# Redis (Production)
REDIS_URL=redis://your-redis-prod.cache.amazonaws.com:6379
REDIS_PASSWORD=your_production_redis_password

# Authentication (Production - Generate strong secrets!)
JWT_SECRET=your_production_jwt_secret_256_bits_min
SESSION_SECRET=your_production_session_secret_256_bits_min

# API Ports (Production may use standard 80/443)
API_PORT=4000
FRONTEND_PORT=3000

# AWS Services (Production)
S3_BUCKET=hootner-uploads-prod
S3_REGION=us-east-1
AWS_S3_BUCKET=hootner-frontend-prod
CLOUDFRONT_DIST_ID=your_production_cloudfront_id
CLOUDFRONT_URL=https://cdn.hootner.com

# Stripe (Production - Use LIVE keys!)
STRIPE_SECRET_KEY=sk_live_your_production_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key

# Video Generation (Production)
VIDEO_GEN_PORT=5003

# Frontend API Endpoints (Production - Use HTTPS and WSS!)
VITE_API_BASE=https://api.hootner.com
VITE_WS_URL=wss://ws.hootner.com
VITE_GRAPHQL_API=https://api.hootner.com/graphql
VITE_GRAPHQL_WS=wss://api.hootner.com/graphql
VITE_VIDEO_API=https://video.hootner.com
VITE_VIDEO_PLAYER_API=https://player.hootner.com
VITE_ANALYTICS_API=https://analytics.hootner.com/api
VITE_WATCH_PARTY_WS=wss://watchparty.hootner.com
VITE_LSP_JAVASCRIPT=wss://lsp.hootner.com/javascript
VITE_LSP_TYPESCRIPT=wss://lsp.hootner.com/typescript
VITE_LSP_PYTHON=wss://lsp.hootner.com/python
VITE_LSP_JAVA=wss://lsp.hootner.com/java
VITE_LSP_CPP=wss://lsp.hootner.com/cpp
VITE_MESSAGES_API=https://api.hootner.com/api/messages
VITE_MARKETPLACE_API=https://api.hootner.com/api/marketplace
VITE_CONTACT_API=https://api.hootner.com/api/contact

# Additional Production Settings
LOG_LEVEL=error
ENABLE_MONITORING=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000
