      "isWholeLine": false
    },
    {
      "text": "FIXME:",
      "color": "#fff",
      "backgroundColor": "#ff9800",
      "overviewRulerColor": "#ff9800",
      "isWholeLine": false
    },
    {
      "text": "TODO:",
      "color": "#000",
      "backgroundColor": "#ffeb3b",
      "overviewRulerColor": "#ffeb3b",
      "isWholeLine": false
    },
    {
      "text": "HACK:",
      "color": "#000",
      "backgroundColor": "#ff5722",
      "overviewRulerColor": "#ff5722",
      "isWholeLine": false
    },
    {
      "text": "NOTE:",
      "color": "#000",
      "backgroundColor": "#03a9f4",
      "overviewRulerColor": "#03a9f4",
      "isWholeLine": false
    },
    {
      "text": "OPTIMIZE:",
      "color": "#000",
      "backgroundColor": "#00bcd4",
      "overviewRulerColor": "#00bcd4",
      "isWholeLine": false
    },
    {
      "text": "PERFORMANCE:",
      "color": "#000",
      "backgroundColor": "#4caf50",
      "overviewRulerColor": "#4caf50",
      "isWholeLine": false
    },
    {
      "text": "REFACTOR:",
      "color": "#fff",
      "backgroundColor": "#9c27b0",
      "overviewRulerColor": "#9c27b0",
      "isWholeLine": false
    },
    {
      "text": "REVIEW:",
      "color": "#000",
      "backgroundColor": "#ffc107",
      "overviewRulerColor": "#ffc107",
      "isWholeLine": false
    },
    {
      "text": "DEPRECATED:",
      "color": "#fff",
      "backgroundColor": "#795548",
      "overviewRulerColor": "#795548",
      "isWholeLine": false
    },
    {
      "text": "CLEANUP:",
      "color": "#fff",
      "backgroundColor": "#607d8b",
      "overviewRulerColor": "#607d8b",
      "isWholeLine": false
    },
    {
      "text": "TEST:",
      "color": "#000",
      "backgroundColor": "#8bc34a",
      "overviewRulerColor": "#8bc34a",
      "isWholeLine": false
    },
    {
      "text": "DOCS:",
      "color": "#fff",
      "backgroundColor": "#3f51b5",
      "overviewRulerColor": "#3f51b5",
      "isWholeLine": false
    }
  ],
  "todohighlight.include": [
    "**/*.js",
    "**/*.jsx",
    "**/*.ts",
    "**/*.tsx",
    "**/*.html",
    "**/*.css",
    "**/*.scss",
    "**/*.json",
    "**/*.md",
    "**/*.yml",
    "**/*.yaml"
  ],
  "todohighlight.exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/.next/**",
    "**/coverage/**",
    "**/.vscode/**",
    "**/.github/**",
    "**/*.min.js",
    "**/*.bundle.js",
    "**/*.map",
    "**/package-lock.json",
    "**/yarn.lock"
  ],
  "todohighlight.maxFilesForSearch": 5120,
  "todohighlight.toggleURI": false,
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.shellIntegration.decorationsEnabled": "both",
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true
  },
  "files.associations": {
    "*.json": "jsonc",
    "Dockerfile*": "dockerfile",
    "*.yaml": "yaml",
    "*.yml": "yaml"
  },
  "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
  "eslint.workingDirectories": ["${workspaceFolder}"],
  "eslint.nodePath": "${workspaceFolder}/node_modules",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "docker.showStartPage": false,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.analysis.extraPaths": ["C:\\Program Files\\Python312\\Lib\\site-packages"],
  "python.autoComplete.extraPaths": ["C:\\Program Files\\Python312\\Lib\\site-packages"],
  "cSpell.words": [
    "HOOTNER",
    "hootner",
    "pytorch",
    "transformers",
    "tokenizer",
    "microservices",
    "kubernetes",
    "graphql",
    "websocket",
    "mongodb",
    "redis",
    "prometheus",
    "grafana",
    "istio",
    "traefik",
    "runbooks",
    "autoregressively",
    "Multihead",
    "GELU",
    "triu",
    "backpropagation",
    "bleu"
  ],
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/coverage": true,
    "**/*.lock": true
  },
  "todo-tree.tree.scanMode": "workspace only",
  "npm.packageManager": "npm"
}
