{
  "amazonQ.mcp.servers": {
    "hootner-deployment": {
      "transport": "stdio",
      "command": "node",
      "args": ["servers/hootner-mcp-server.js"],
      "cwd": "${workspaceFolder}",
      "env": {
        "HOOTNER_ENV": "development",
        "NODE_ENV": "production"
      }
    },
    "aws-cdk": {
      "transport": "stdio",
      "command": "uvx",
      "args": ["awslabs.cdk-mcp-server@latest"],
      "env": {
        "AWS_PROFILE": "default"
      }
    }
  },
  "amazonQ.mcp.toolPermissions": {
    "hootner-deployment": {
      "deploy_service": "ask",
      "run_chaos_test": "ask",
      "check_system_health": "always",
      "backup_system": "ask",
      "security_audit": "always"
    }
  },
  "todo-tree.general.tags": [
    "TODO",
    "FIXME",
    "BUG",
    "HACK",
    "XXX",
    "NOTE",
    "OPTIMIZE",
    "REFACTOR",
    "SECURITY",
    "PERFORMANCE",
    "DEPRECATED",
    "REVIEW",
    "CLEANUP",
    "TEST",
    "DOCS",
    "[ ]",
    "[x]"
  ],
  "todo-tree.general.tagGroups": {
    "FIXME": ["FIXME", "FIX", "FIXIT"],
    "BUG": ["BUG", "ISSUE", "ERROR"],
    "SECURITY": ["SECURITY", "SEC", "VULN", "CVE"]
  },
  "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^|^\\s*(-|\\d+.))\\s*($TAGS)",
  "todo-tree.highlights.enabled": true,
  "todo-tree.highlights.useColourScheme": true,
  "todo-tree.highlights.defaultHighlight": {
    "type": "text-and-comment",
    "opacity": 50
  },
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "check",
      "foreground": "#000",
      "background": "#ffeb3b",
      "iconColour": "#ffeb3b"
    },
    "FIXME": {
      "icon": "tools",
      "foreground": "#fff",
      "background": "#ff9800",
      "iconColour": "#ff9800",
      "gutterIcon": true
    },
    "BUG": {
      "icon": "bug",
      "foreground": "#fff",
      "background": "#f44336",
      "iconColour": "#f44336",
      "gutterIcon": true
    },
    "SECURITY": {
      "icon": "shield",
      "foreground": "#fff",
      "background": "#d32f2f",
      "iconColour": "#d32f2f",
      "gutterIcon": true
    },
    "PERFORMANCE": {
      "icon": "zap",
      "foreground": "#000",
      "background": "#4caf50",
      "iconColour": "#4caf50"
    },
    "OPTIMIZE": {
      "icon": "rocket",
      "foreground": "#000",
      "background": "#00bcd4",
      "iconColour": "#00bcd4"
    },
    "REFACTOR": {
      "icon": "code",
      "foreground": "#fff",
      "background": "#9c27b0",
      "iconColour": "#9c27b0"
    },
    "HACK": {
      "icon": "alert",
      "foreground": "#000",
      "background": "#ff5722",
      "iconColour": "#ff5722"
    },
    "NOTE": {
      "icon": "note",
      "foreground": "#000",
      "background": "#03a9f4",
      "iconColour": "#03a9f4"
    },
    "DEPRECATED": {
      "icon": "x",
      "foreground": "#fff",
      "background": "#795548",
      "iconColour": "#795548"
    },
    "REVIEW": {
      "icon": "eye",
      "foreground": "#000",
      "background": "#ffc107",
      "iconColour": "#ffc107"
    },
    "CLEANUP": {
      "icon": "trash",
      "foreground": "#fff",
      "background": "#607d8b",
      "iconColour": "#607d8b"
    },
    "TEST": {
      "icon": "beaker",
      "foreground": "#000",
      "background": "#8bc34a",
      "iconColour": "#8bc34a"
    },
    "DOCS": {
      "icon": "book",
      "foreground": "#fff",
      "background": "#3f51b5",
      "iconColour": "#3f51b5"
    },
    "[ ]": {
      "icon": "issue-opened",
      "background": "#ff000040",
      "iconColour": "#ff0000"
    },
    "[x]": {
      "icon": "check",
      "background": "#00ff0040",
      "iconColour": "#00ff00"
    }
  },
  "todo-tree.filtering.excludeGlobs": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/out/**",
    "**/.next/**",
    "**/coverage/**",
    "**/*.min.js",
    "**/*.bundle.js",
    "**/package-lock.json",
    "**/yarn.lock"
  ],
  "todo-tree.filtering.includeGlobs": [],
  "todo-tree.general.statusBar": "total",
  "todo-tree.general.showActivityBarBadge": true,
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.tree.grouped": true,
  "todo-tree.tree.expanded": true,
  "todo-tree.tree.labelFormat": "${tag} ${after}",
  "todo-tree.tree.tooltipFormat": "${filepath}, line ${line}: ${after}",
  "todo-tree.tree.buttons.scanMode": true,
  "todo-tree.tree.buttons.export": true,
  "todo-tree.filtering.scopes": [
    {
      "name": "Frontend",
      "includeGlobs": ["**/apps/frontend/**"]
    },
    {
      "name": "Backend Services",
      "includeGlobs": ["**/services/**", "**/api/**"]
    },
    {
      "name": "Infrastructure",
      "includeGlobs": ["**/infrastructure/**", "**/k8s/**"]
    },
    {
      "name": "Security Only",
      "includeGlobs": ["**/*"],
      "tags": ["SECURITY", "BUG", "FIXME"]
    },
    {
      "name": "Documentation",
      "includeGlobs": ["**/docs/**", "**/*.md"]
    },
    {
      "name": "All"
    }
  ],
  "todohighlight.isEnable": true,
  "todohighlight.isCaseSensitive": false,
  "todohighlight.keywords": [
    {
      "text": "SECURITY:",
      "color": "#fff",
      "backgroundColor": "#d32f2f",
