# HOOTNER Environment Configuration
NODE_ENV=development
PORT=3000

# CORS Security - Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000

# AWS Configuration
AWS_REGION=us-east-1
AWS_STACK_NAME=hootner-dev

# Database
DYNAMODB_ENDPOINT=
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security - REQUIRED (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-minimum-32-chars-change-in-production
REFRESH_SECRET=your-secure-refresh-secret-minimum-32-chars-change-in-production
SESSION_SECRET=your-secure-session-secret-minimum-32-chars-change-in-production
INTERNAL_SERVICE_TOKEN=your-secure-internal-token-minimum-32-chars-change-in-production

# API Keys (Replace with actual values)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# AWS Access (Use AWS Secrets Manager in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Feature Flags
ENABLE_DUAL_AGENT=true
ENABLE_AI_SERVICES=true
ENABLE_MONITORING=true