# HOOTNER Environment Configuration
NODE_ENV=development
PORT=3000

# CORS Security - Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000

# AWS Configuration
AWS_REGION=us-east-1
AWS_STACK_NAME=hootner-dev

# S3 Tables (Table Buckets) - optional
# Name rules: 3-63 chars, lowercase a-z, 0-9, hyphens; must be unique per account+region.
# Suggested pattern: hootner-tables-${accountId}-${region}
AWS_S3_TABLE_BUCKET_NAME=

# Account/Region integration that exposes table buckets to analytics engines (Glue/Lake Formation)
# Note: In AWS this is an account+region setting; values here are informational and for validation.
AWS_S3_TABLES_ANALYTICS_INTEGRATION_ENABLED=true

# Default storage class for new tables in the table bucket (leave blank to "Don't specify")
# Allowed: (blank), STANDARD, INTELLIGENT_TIERING
AWS_S3_TABLES_DEFAULT_STORAGE_CLASS=

# Default encryption for new tables (leave blank to "Don't specify")
# Allowed: (blank), SSE-S3, SSE-KMS
AWS_S3_TABLES_DEFAULT_ENCRYPTION=
AWS_S3_TABLES_KMS_KEY_ID=

# Optional tags applied during provisioning (format: Key=Value,Key2=Value2)
AWS_S3_TABLES_TAGS=Project=HOOTNER,Env=dev

# Database
DYNAMODB_ENDPOINT=
REDIS_URL=redis://localhost:6379

# API Keys (Replace with actual values)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
JWT_SECRET=your-jwt-secret-here

# Feature Flags
ENABLE_DUAL_AGENT=true
ENABLE_AI_SERVICES=true
ENABLE_MONITORING=true