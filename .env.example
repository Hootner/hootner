# HOOTNER - Hexagonal Architecture Environment
NODE_ENV=development
PORT=3000

# Hexagonal Layer Configurations
CORE_DOMAIN_PORT=3001
FOUNDATION_INFRA_PORT=3002
INTELLIGENCE_AI_PORT=3003
COMMUNICATION_API_PORT=3004
INTERFACE_UI_PORT=3005
ECONOMY_BUSINESS_PORT=3006
GOVERNANCE_SECURITY_PORT=3007
DATA_REPOSITORY_PORT=3008
OPERATIONS_DEVOPS_PORT=3009

# Database
DATABASE_URL=mongodb://localhost:27017/hootner
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_KEY=your-encryption-key-here

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# External Services
STRIPE_SECRET_KEY=sk_test_your-stripe-key
FIREBASE_PROJECT_ID=your-firebase-project

# Logging
LOG_LEVEL=info
LOG_FORMAT=json