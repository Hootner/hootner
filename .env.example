# Database - Use strong credentials in production
MONGODB_URI=mongodb://admin:${MONGODB_PASSWORD}@localhost:27017/hootner?authSource=admin
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
JWT_SECRET=${JWT_SECRET:-generate-strong-secret-32-chars-min}
API_PORT=4000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=${INTERNAL_SERVICE_TOKEN:-change-in-production}

# Stripe Payment Integration
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}

# Security Keys - Generate strong keys for production
ENCRYPTION_KEY=${ENCRYPTION_KEY:-generate-32-char-encryption-key}
SESSION_SECRET=${SESSION_SECRET:-generate-32-char-session-secret}

# Environment
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security Headers
CSP_REPORT_URI=/api/csp-report
HSTS_MAX_AGE=31536000

# SECURITY NOTE:
# - Use 32+ character secrets in production
# - Never commit .env file to version control
# - Rotate secrets every 90 days
# - Use different secrets for dev/staging/production
