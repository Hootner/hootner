# HOOTNER Environment Configuration

# Node Environment
NODE_ENV=development

# ============================================
# API Endpoints Configuration
# ============================================
# These variables configure all API endpoints used by the frontend
# Defaults are set for local development - override for staging/production

# Main REST API
VITE_API_BASE=http://localhost:4000

# Main WebSocket
VITE_WS_URL=ws://localhost:3005

# GraphQL API
VITE_GRAPHQL_API=http://localhost:4000/graphql
VITE_GRAPHQL_WS=ws://localhost:4000/graphql

# Video Services
VITE_VIDEO_API=http://localhost:5003
VITE_VIDEO_PLAYER_API=http://localhost:3000

# Analytics
VITE_ANALYTICS_API=http://localhost:5003/api/analytics

# Watch Party
VITE_WATCH_PARTY_WS=ws://localhost:5004

# Language Server Protocol (LSP) Endpoints
VITE_LSP_JAVASCRIPT=ws://localhost:3001/lsp/javascript
VITE_LSP_TYPESCRIPT=ws://localhost:3001/lsp/typescript
VITE_LSP_PYTHON=ws://localhost:3001/lsp/python
VITE_LSP_JAVA=ws://localhost:3001/lsp/java
VITE_LSP_CPP=ws://localhost:3001/lsp/cpp

# Specific API Endpoints
VITE_MESSAGES_API=http://localhost:4000/api/messages
VITE_MARKETPLACE_API=http://localhost:4000/api/marketplace
VITE_CONTACT_API=http://localhost:4000/api/contact

# ============================================
# AWS Deployment Configuration
# ============================================
# Required for deploying to AWS (staging/production)
# Leave empty for local development

# CloudFront Distribution ID (REQUIRED for deployment)
CLOUDFRONT_DIST_ID=

# CloudFront URL (optional, for custom domain)
CLOUDFRONT_URL=

# S3 Bucket for frontend assets
AWS_S3_BUCKET=hootner-frontend

# AWS Region
AWS_REGION=us-east-1

# ============================================
# Database Configuration
# ============================================

# Database - DynamoDB
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_NAME=hootner-dev

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=dev_redis_password

# ============================================
# Authentication & Security
# ============================================

# Authentication
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# ============================================
# Application Ports
# ============================================

# API
API_PORT=4000
FRONTEND_PORT=3000

# Video Generation
VIDEO_GEN_PORT=5003

# ============================================
# Third-Party Services
# ============================================

# AWS Services
S3_BUCKET=hootner-uploads
S3_REGION=us-east-1

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key
