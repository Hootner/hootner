# NPM Satellite Optimization
# Reduces bandwidth usage

# Use cache aggressively
prefer-offline=true
cache-min=9999999

# Compress downloads
fetch-retries=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Skip optional dependencies
optional=false
save-optional=false

# Enable package-lock for security audits
package-lock=true
