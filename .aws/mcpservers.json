{
  "mcpServers": {
    "awslabs.cdk-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.cdk-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "INFO"
      },
      "timeout": 60000
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "timeout": 60000
    },
    "context7": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "MCP_TRANSPORT",
        "-e",
        "PORT",
        "mcp/context7"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio",
        "PORT": "8089"
      },
      "timeout": 60000
    },
    "local-tooling": {
      "command": "C:\\\\tools\\\\mcp\\\\my-server.exe",
      "args": [],
      "env": {},
      "workingDirectory": "C:\\\\tools\\\\mcp",
      "timeout": 60000
    }
  }
}
