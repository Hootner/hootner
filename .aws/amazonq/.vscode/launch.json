{
  "http.proxyStrictSSL": false,
  "http.electronFetch": true,
  "http.experimental.systemCertificatesV2": true,
  "aws.toolkit.telemetry": false,
  "amazonQ.shareContentWithAWS": false,
  "amazonQ.proxy.certificateAuthority": "",
  "amazonQ.workspaceIndexMaxFileSize": 10,
  "amazonQ.workspaceIndexUseGPU": true,
  "amazonQ.allowFeatureDevelopmentToRunCodeAndTests": {
    "enabled": true
  },
  "editor.accessibilitySupport": "off",
  "editor.fontSize": 16,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "editor.largeFileOptimizations": false,
  "files.autoSave": "afterDelay",
  "grunt.autoDetect": "on",
  "makefile.configureOnOpen": true,
  "python.defaultInterpreterPath": "c:\\Python313\\python.exe",
  "remote.tunnels.alwaysUpdateCLI": true,
  "remote.autoForwardPorts": false,
  "chat.commandCenter.enabled": false,
  "chat.mcp.autostart": "newAndOutdated",
  "workbench.colorTheme": "Abyss",
  "workbench.editor.empty.hint": "hidden",
  "workbench.settings.applyToAllProfiles": [],
  "window.newWindowProfile": "Default",
  "aws.profile": "Michael",
  "terminal.integrated.defaultProfile.windows": "PowerShell 7x",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ],
      "args": [],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "source": "Git Bash"
    },
    "PowerShell 7x": {
      "path": "C:\\Program Files\\PowerShell\\7\\pwsh.exe"
    }
  },
  "workbench.editorAssociations": {
    "{git,gitlens,conflictResolution,vscode-local-history}:/**/*.tc.json": "default",
    "{git,gitlens,conflictResolution,vscode-local-history}:/**/*.{asl.json,asl.yaml,asl.yml}": "default",
    "*.vsidx": "default"
  },
  "launch": {
    "configurations": [
      {
        "type": "aws-sam",
        "request": "direct-invoke",
        "name": "Invoke Lambda with API Gateway",
        "invokeTarget": {
          "target": "api",
          "templatePath": "${workspaceFolder}/template.yaml",
          "logicalId": "PostServiceFunction"
        },
        "api": {
          "path": "/posts/{id}",
          "httpMethod": "post",
          "payload": {
            "json": {
              "id": "12345"
            }
          }
        }
      },
      {
        "type": "aws-sam",
        "request": "direct-invoke",
        "name": "Invoke Lambda Direct",
        "invokeTarget": {
          "target": "template",
          "templatePath": "${workspaceFolder}/template.yaml",
          "logicalId": "AnalyticsServiceFunction"
        },
        "lambda": {
          "payload": {
            "json": {
              "userId": "abc123",
              "action": "view"
            }
          }
        }
      }
    ]
  }
}
