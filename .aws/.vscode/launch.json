{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "aws-sam",
      "request": "direct-invoke",
      "name": "Invoke Lambda with API Gateway",
      "invokeTarget": {
        "target": "api",
        "templatePath": "${workspaceFolder}/template.yaml",
        "logicalId": "PostServiceFunction"
      },
      "api": {
        "path": "/posts/{id}",
        "httpMethod": "post",
        "payload": {
          "json": {
            "id": "12345"
          }
        }
      }
    },
    {
      "type": "aws-sam",
      "request": "direct-invoke",
      "name": "Invoke Lambda Direct",
      "invokeTarget": {
        "target": "template",
        "templatePath": "${workspaceFolder}/template.yaml",
        "logicalId": "AnalyticsServiceFunction"
      },
      "lambda": {
        "payload": {
          "json": {
            "userId": "abc123",
            "action": "view"
          }
        }
      }
    }
  ]
}
