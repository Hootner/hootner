---
import Layout from '../layouts/Layout.astro';
import StatCard from '../components/StatCard.astro';
---
<Layout title="Dashboard">
  <h1 class="text-4xl font-bold mb-8">Dashboard</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <StatCard label="Total Videos" value="0" />
    <StatCard label="Total Views" value="0" />
    <StatCard label="Storage Used" value="0 GB" />
    <StatCard label="Active Projects" value="0" />
  </div>
  
  <div class="glass-card p-6">
    <h2 class="text-2xl font-bold mb-4">Quick Actions</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <a href="/upload-video" class="bg-primary text-black px-4 py-3 rounded-lg font-bold hover:bg-primary/80 text-center">Upload Video</a>
      <a href="/ai-video" class="bg-secondary text-black px-4 py-3 rounded-lg font-bold hover:bg-secondary/80 text-center">AI Generate</a>
      <a href="/live-stream" class="bg-accent text-black px-4 py-3 rounded-lg font-bold hover:bg-accent/80 text-center">Go Live</a>
      <a href="/analytics" class="bg-gray-700 text-white px-4 py-3 rounded-lg font-bold hover:bg-gray-600 text-center">Analytics</a>
    </div>
  </div>
</Layout>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
