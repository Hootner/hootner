---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Profile">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-4xl font-bold mb-8">Profile</h1>
    
    <div class="glass-card p-8">
      <div class="flex items-center mb-6">
        <div class="w-24 h-24 bg-gray-700 rounded-full mr-6"></div>
        <button class="bg-primary text-black px-4 py-2 rounded font-bold">Change Avatar</button>
      </div>
      
      <form class="space-y-4">
        <div>
          <label class="block text-sm mb-2">Display Name</label>
          <input type="text" class="w-full bg-gray-800 rounded px-4 py-2 text-white">
        </div>
        <div>
          <label class="block text-sm mb-2">Bio</label>
          <textarea class="w-full bg-gray-800 rounded px-4 py-2 h-32 text-white"></textarea>
        </div>
        <div>
          <label class="block text-sm mb-2">Website</label>
          <input type="url" class="w-full bg-gray-800 rounded px-4 py-2 text-white">
        </div>
        <button type="submit" class="bg-primary text-black px-6 py-2 rounded font-bold hover:bg-primary/80 w-full">
          Save Changes
        </button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
