---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-4xl font-bold mb-8">Contact Us</h1>
    
    <div class="glass-card p-8">
      <form class="space-y-4">
        <div>
          <label class="block text-sm mb-2">Name</label>
          <input type="text" class="w-full bg-gray-800 rounded px-4 py-2 text-white">
        </div>
        <div>
          <label class="block text-sm mb-2">Email</label>
          <input type="email" class="w-full bg-gray-800 rounded px-4 py-2 text-white">
        </div>
        <div>
          <label class="block text-sm mb-2">Subject</label>
          <input type="text" class="w-full bg-gray-800 rounded px-4 py-2 text-white">
        </div>
        <div>
          <label class="block text-sm mb-2">Message</label>
          <textarea class="w-full bg-gray-800 rounded px-4 py-2 h-32 text-white"></textarea>
        </div>
        <button type="submit" class="bg-primary text-black px-6 py-2 rounded font-bold hover:bg-primary/80 w-full">
          Send Message
        </button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
