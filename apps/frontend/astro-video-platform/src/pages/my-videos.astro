---
import Layout from '../layouts/Layout.astro';
import VideoCard from '../components/VideoCard.astro';
---
<Layout title="My Videos">
  <h1 class="text-4xl font-bold mb-8">My Videos</h1>
  
  <div class="mb-6">
    <input type="text" placeholder="Search videos..." class="w-full bg-gray-800 rounded px-4 py-2 text-white">
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="glass-card p-8 text-center">
      <p class="text-gray-400">No videos yet</p>
      <a href="/upload-video" class="inline-block mt-4 bg-primary text-black px-6 py-2 rounded font-bold hover:bg-primary/80">
        Upload Your First Video
      </a>
    </div>
  </div>
</Layout>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
