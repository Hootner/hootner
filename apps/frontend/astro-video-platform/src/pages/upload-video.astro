---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Upload Video">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-4xl font-bold mb-8">Upload Video</h1>
    
    <div class="glass-card p-8" x-data="{ file: null, uploading: false, progress: 0 }" client:load>
      <div 
        @drop.prevent="file = $event.dataTransfer.files[0]"
        @dragover.prevent
        class="border-2 border-dashed border-primary rounded-lg p-12 text-center mb-6 cursor-pointer hover:bg-white/5"
        @click="$refs.fileInput.click()"
      >
        <p class="text-xl mb-4" x-text="file ? file.name : 'Drop video here or click to browse'"></p>
        <input type="file" x-ref="fileInput" @change="file = $event.target.files[0]" class="hidden" accept="video/*">
      </div>
      
      <div x-show="uploading" class="mb-6">
        <div class="bg-gray-700 rounded-full h-4">
          <div class="bg-primary h-4 rounded-full transition-all" :style="`width: ${progress}%`"></div>
        </div>
        <p class="text-center mt-2" x-text="`${progress}% uploaded`"></p>
      </div>
      
      <form class="space-y-4" x-show="file" @submit.prevent="uploading = true; progress = 100">
        <input type="text" placeholder="Title" class="w-full bg-gray-800 rounded px-4 py-2 text-white">
        <textarea placeholder="Description" class="w-full bg-gray-800 rounded px-4 py-2 h-32 text-white"></textarea>
        <input type="text" placeholder="Tags (comma separated)" class="w-full bg-gray-800 rounded px-4 py-2 text-white">
        <button type="submit" class="bg-primary text-black px-6 py-2 rounded font-bold hover:bg-primary/80 w-full">
          Upload
        </button>
      </form>
    </div>
  </div>
</Layout>

<style>
  .glass-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
