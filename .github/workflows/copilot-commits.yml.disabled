# DISABLED
name: Copilot Commit Management

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main ]

jobs:
  copilot-review:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '25.2.1'
          
      - name: Install dependencies
        run: npm install
        
      - name: Copilot Code Review
        uses: github/copilot-cli-action@v1
        with:
          command: 'review'
          
      - name: Security Scan
        run: npm run security:audit
        
      - name: Generate Commit Message
        if: github.event_name == 'push'
        run: |
          echo "COPILOT_COMMIT_MSG=$(gh copilot suggest -t commit)" >> $GITHUB_ENV
          
      - name: Auto-format Commit
        if: github.event_name == 'push'
        run: |
          git config --local user.email "copilot@hootner.com"
          git config --local user.name "GitHub Copilot"